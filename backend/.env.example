# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration (PostgreSQL)
DB_USER=postgres
DB_HOST=localhost
DB_DATABASE=repair_shop
DB_PASSWORD=your_db_password
DB_PORT=5432

# JWT Authentication
JWT_SECRET=super_secret_key_change_me_in_production
JWT_EXPIRES_IN=7d

# Email SMTP Settings (For OTP - optional, app falls back to console logging if not set)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
EMAIL_FROM=noreply@electronicsrepair.com
